<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f1117">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:text="Nouvelle dépense"
                android:textColor="#e8eaf0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView android:text="Nom de l'employé"
                android:textColor="#7a7f99" android:textSize="13sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etNom"
                android:hint="ex: Sam Anis" android:textColorHint="#7a7f99"
                android:textColor="#e8eaf0" android:background="@drawable/input_bg"
                android:padding="12dp" android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

            <TextView android:text="Coût du vol ($)"
                android:textColor="#7a7f99" android:textSize="13sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etVol"
                android:hint="0.00" android:inputType="numberDecimal"
                android:textColorHint="#7a7f99" android:textColor="#e8eaf0"
                android:background="@drawable/input_bg" android:padding="12dp"
                android:layout_marginTop="6dp" android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

            <TextView android:text="Hébergement ($)"
                android:textColor="#7a7f99" android:textSize="13sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etHebergement"
                android:hint="0.00" android:inputType="numberDecimal"
                android:textColorHint="#7a7f99" android:textColor="#e8eaf0"
                android:background="@drawable/input_bg" android:padding="12dp"
                android:layout_marginTop="6dp" android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

            <TextView android:text="Repas ($)"
                android:textColor="#7a7f99" android:textSize="13sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etRepas"
                android:hint="0.00" android:inputType="numberDecimal"
                android:textColorHint="#7a7f99" android:textColor="#e8eaf0"
                android:background="@drawable/input_bg" android:padding="12dp"
                android:layout_marginTop="6dp" android:layout_marginBottom="24dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

            <Button android:id="@+id/btnCalculer"
                android:text="Calculer →" android:backgroundTint="#4f8ef7"
                android:textColor="#ffffff" android:textStyle="bold"
                android:layout_width="match_parent" android:layout_height="52dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1a1d27"
        app:itemIconTint="#4f8ef7"
        app:itemTextColor="#4f8ef7"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>